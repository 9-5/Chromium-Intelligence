{
    "manifest_version": 3,
    "name": "AI Writing Assistant",
    "version": "1.0",
    "description": "A Chrome extension that assists with text rewriting, summarization, and more.",
    "permissions": [
        "contextMenus",
        "storage",
        "activeTab"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": ["<all_urls>"],
            "js": ["contents.js"]
        }
    ],
    "action": {
        "default_popup": "popup.html"
    }
}